/**
 * Helper: filter listings by maximum price
 * @param {number} maxPrice
 * @returns {Array}
 */
function filterByMaxPrice(maxPrice) {
  return listings.filter(l => l.price <= maxPrice);
}
 
/**
 * Helper: filter listings by area/location keyword
 * @param {string} keyword
 * @returns {Array}
 */
function filterByArea(keyword) {
  const kw = keyword.toLowerCase();
  return listings.filter(l =>
    l.area.toLowerCase().includes(kw) ||
    l.community.toLowerCase().includes(kw) ||
    l.subdivision.toLowerCase().includes(kw) ||
    l.name.toLowerCase().includes(kw)
  );
}
 
/**
 * Helper: filter listings by price range
 * @param {number} minPrice
 * @param {number} maxPrice
 * @returns {Array}
 */
function filterByPriceRange(minPrice, maxPrice) {
  return listings.filter(l => l.price >= minPrice && l.price <= maxPrice);
}
 
/**
 * Helper: get listings by status
 * @param {string} status - "Active" | "New Listing" | "Back on Market"
 * @returns {Array}
 */
function filterByStatus(status) {
  return listings.filter(l => l.status === status);
}
 
/**
 * Helper: sort listings by price ascending
 * @returns {Array}
 */
function sortByPriceAsc() {
  return [...listings].sort((a, b) => a.price - b.price);
}
 
/**
 * Helper: sort listings by price descending
 * @returns {Array}
 */
function sortByPriceDesc() {
  return [...listings].sort((a, b) => b.price - a.price);
}
 
// Export for Node.js / ES module environments
if (typeof module !== "undefined" && module.exports) {
  module.exports = { listings, filterByMaxPrice, filterByArea, filterByPriceRange, filterByStatus, sortByPriceAsc, sortByPriceDesc };
}
